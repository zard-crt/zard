<view class="page projects">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="page-header">
    <text class="page-title">项目</text>
    <text class="page-subtitle">所有诊断项目一览</text>
  </view>
  <view class="opc-role-switch" bindtap="onRoleSwitch">
    <svg viewBox="0 0 20 20" width="14" height="14">
      <path d="M4 10a6 6 0 0110.5-4M16 10a6 6 0 01-10.5 4" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="none" stroke-linecap="round"/>
      <path d="M15.5 3.5L14.5 6l2.5-1M4.5 16.5L5.5 14l-2.5 1" stroke="rgba(255,255,255,0.6)" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <text class="opc-role-switch-text">切换至企业端</text>
    <svg viewBox="0 0 12 12" width="10" height="10">
      <path d="M4 2l4 4-4 4" stroke="rgba(255,255,255,0.6)" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </view>
  </view>
  <scroll-view class="filter-tabs" scroll-x="true" show-scrollbar="false">
    <view wx:for="{{filterTabs}}" wx:key="index" class="filter-tab-wrap">
      <view class="filter-tab {{currentFilter === index ? 'active' : ''}}" bindtap="onFilterTab" data-index="{{index}}">
        <text>{{item}}</text>
        <view class="filter-indicator {{currentFilter === index ? 'filter-indicator--active' : ''}}"></view>
      </view>
    </view>
  </scroll-view>
  <scroll-view class="project-list" scroll-y="true" style="height: {{listHeight}}px;" bindscrolltolower="onLoadMore">
    <view wx:if="{{projects.length === 0}}" class="empty-state">
      <svg class="empty-icon" viewBox="0 0 64 64" width="64" height="64" fill="none">
        <rect x="8" y="16" width="48" height="36" rx="6" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
        <path d="M22 30h20M22 38h14" stroke="rgba(255,255,255,0.15)" stroke-width="2" stroke-linecap="round"/>
        <path d="M32 8l-4 4h8l-4-4z" fill="rgba(255,159,10,0.3)"/>
        <circle cx="44" cy="42" r="8" fill="rgba(255,159,10,0.15)" stroke="#FF9F0A" stroke-width="1.5"/>
        <path d="M44 38v8M40 42h8" stroke="#FF9F0A" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <text class="empty-title">暂无项目</text>
      <text class="empty-desc">当前筛选条件下没有诊断项目</text>
    </view>
    <view
      wx:for="{{projects}}"
      wx:key="index"
      class="project-card card-enter {{animateItems[index] === 'entering' ? 'card-enter--active' : ''}}"
      bindtap="onProjectTap"
      data-id="{{item.id}}"
      style="animation-delay: {{index * 0.06}}s"
    >
      <view class="card-header">
        <view class="company-info">
          <view class="company-avatar-lg">
            <text class="company-initial">{{item.companyInitial}}</text>
          </view>
          <view class="company-text">
            <text class="company-name">{{item.company}}</text>
            <view class="status-row">
              <view class="status-dot status-dot--{{item.statusClass}}"></view>
              <text class="status-text">{{item.statusText}}</text>
            </view>
          </view>
        </view>
        <svg class="arrow-icon" viewBox="0 0 24 24" width="18" height="18" fill="none">
          <path d="M9 6l6 6-6 6" stroke="rgba(255,255,255,0.25)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </view>
      <view class="card-body">
        <view class="progress-section">
          <view class="progress-bar-bg">
            <view class="progress-bar-fill" style="width: {{item.progress}}%;"></view>
          </view>
          <text class="progress-text">{{item.progress}}%</text>
        </view>
      </view>
      <view class="card-footer">
        <view class="footer-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
            <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <text class="footer-text">{{item.members}}人参与</text>
        </view>
        <view class="footer-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none">
            <rect x="3" y="4" width="18" height="18" rx="2" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M8 2v4M16 2v4M3 10h18" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <text class="footer-text">{{item.date}}</text>
        </view>
      </view>
    </view>
    <view wx:if="{{loading}}" class="loading-more"><text>加载中...</text></view>
    <view wx:if="{{noMore && projects.length > 0}}" class="no-more"><text>没有更多了</text></view>
    <view style="height: 20px;"></view>
  </scroll-view>
  <view style="height: 80px;"></view>
  <tab-bar type="opc" active="0" bind:tap="onTabTap"></tab-bar>
</view>
