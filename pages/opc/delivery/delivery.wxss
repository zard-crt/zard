.page.delivery { min-height: 100vh; background: #1D1D1F; }
.page-header { padding: 0 20px; margin-top: 12px; margin-bottom: 20px; }
.page-title { font-size: 26px; font-weight: 700; color: rgba(255,255,255,0.85); display: block; line-height: 34px; }
.page-subtitle { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-top: 4px; }

/* Glass card */
.glass-card { background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin: 0 20px 12px; }

/* Form header */
.form-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.form-label-row { display: flex; align-items: center; gap: 6px; margin-bottom: 10px; }
.form-label { font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.85); }
.sub-label { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8px; }

/* Form inputs */
.form-input { width: 100%; height: 44px; background: rgba(255,255,255,0.06); border-radius: 10px; padding: 0 14px; font-size: 14px; color: rgba(255,255,255,0.85); box-sizing: border-box; border: 0.5px solid rgba(255,255,255,0.06); }
.form-input:focus { border-color: rgba(255,159,10,0.3); }
.placeholder { color: rgba(255,255,255,0.25); font-size: 14px; }
.form-textarea { width: 100%; min-height: 80px; background: rgba(255,255,255,0.06); border-radius: 10px; padding: 10px 14px; font-size: 14px; color: rgba(255,255,255,0.85); box-sizing: border-box; line-height: 1.5; border: 0.5px solid rgba(255,255,255,0.06); }

/* Phase items */
.phase-item { margin-bottom: 12px; padding: 12px; background: rgba(255,255,255,0.03); border-radius: 10px; border: 0.5px solid rgba(255,255,255,0.05); }
.phase-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.phase-number-row { display: flex; align-items: center; gap: 6px; }
.phase-badge { width: 18px; height: 18px; border-radius: 9px; background: rgba(255,159,10,0.15); color: #FF9F0A; font-size: 10px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.phase-number { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); }
.delete-btn { width: 28px; height: 28px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
.delete-btn:active { background: rgba(255,69,58,0.15); }
.phase-name { margin-bottom: 8px; }

/* Add phase button */
.add-btn { display: flex; align-items: center; gap: 4px; padding: 5px 12px; border-radius: 8px; background: rgba(255,159,10,0.12); font-size: 12px; color: #FF9F0A; font-weight: 500; }
.add-btn:active { background: rgba(255,159,10,0.2); }

/* Tag selection */
.tag-list { display: flex; flex-wrap: wrap; gap: 8px; }
.tag {
  display: flex; align-items: center; gap: 5px;
  padding: 7px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1);
  font-size: 12px; color: rgba(255,255,255,0.5);
  transition: all 0.25s ease;
}
.tag:active { transform: scale(0.95); }
.tag.active { background: rgba(255,159,10,0.12); color: #FF9F0A; border-color: rgba(255,159,10,0.3); }
.tag-check { width: 14px; height: 14px; border-radius: 3px; border: 1.5px solid rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; }
.tag-check--active { background: #FF9F0A; border-color: #FF9F0A; }

/* Action buttons */
.action-buttons { padding: 8px 20px 0; display: flex; flex-direction: column; gap: 10px; }
.btn-primary {
  background: linear-gradient(135deg, #FF9F0A 0%, #FFCC02 100%);
  color: #1D1D1F;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  line-height: 48px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
.btn-secondary {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.8);
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  line-height: 48px;
  border: 0.5px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.btn-secondary::after { border: none; }
.btn-secondary:active { background: rgba(255,255,255,0.1); }
