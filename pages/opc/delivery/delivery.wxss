.page.delivery { min-height: 100vh; background: #1D1D1F; }
.page-header { padding: 0 20px; margin-top: 12px; margin-bottom: 20px; }
.page-title { font-size: 26px; font-weight: 700; color: rgba(255,255,255,0.85); display: block; line-height: 34px; }
.page-subtitle { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-top: 4px; }
.glass-card { background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin: 0 20px 12px; }
.form-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.form-label { font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; margin-bottom: 8px; }
.sub-label { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8px; }
.form-input { width: 100%; height: 44px; background: rgba(255,255,255,0.06); border-radius: 10px; padding: 0 14px; font-size: 14px; color: rgba(255,255,255,0.85); box-sizing: border-box; }
.placeholder { color: rgba(255,255,255,0.25); font-size: 14px; }
.form-textarea { width: 100%; min-height: 80px; background: rgba(255,255,255,0.06); border-radius: 10px; padding: 10px 14px; font-size: 14px; color: rgba(255,255,255,0.85); box-sizing: border-box; line-height: 1.5; }
.phase-item { margin-bottom: 12px; padding: 12px; background: rgba(255,255,255,0.03); border-radius: 10px; }
.phase-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.phase-number { font-size: 13px; font-weight: 600; color: #FF9F0A; }
.delete-btn { padding: 2px 8px; font-size: 11px; color: #FF453A; }
.phase-name { margin-bottom: 8px; }
.add-btn { padding: 4px 10px; border-radius: 8px; background: rgba(255,159,10,0.15); font-size: 12px; color: #FF9F0A; font-weight: 500; }
.tag-list { display: flex; flex-wrap: wrap; gap: 8px; }
.tag { padding: 6px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.12); font-size: 12px; color: rgba(255,255,255,0.5); }
.tag.active { background: rgba(255,159,10,0.2); color: #FF9F0A; border-color: #FF9F0A; }
.action-buttons { padding: 8px 20px 0; display: flex; flex-direction: column; gap: 10px; }
.btn-primary { background: #FF9F0A; color: #1D1D1F; font-size: 16px; font-weight: 600; border-radius: 12px; height: 48px; line-height: 48px; border: none; }
.btn-primary::after { border: none; }
.btn-secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); font-size: 16px; font-weight: 600; border-radius: 12px; height: 48px; line-height: 48px; border: none; }
.btn-secondary::after { border: none; }
