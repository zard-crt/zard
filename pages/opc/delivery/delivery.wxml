<view class="page delivery">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="page-header"><text class="page-title">方案交付</text><text class="page-subtitle">构建并提交诊断方案</text></view>
  <scroll-view scroll-y="true" style="height: {{contentHeight}}px;">
    <view class="glass-card">
      <text class="form-label">方案名称</text>
      <input class="form-input" placeholder="请输入方案名称" placeholder-class="placeholder" value="{{planName}}" bindinput="onNameInput" />
    </view>
    <view class="glass-card">
      <view class="form-header"><text class="form-label">分阶段内容</text><view class="add-btn" bindtap="onAddPhase"><text>+ 添加阶段</text></view></view>
      <view class="phase-item" wx:for="{{phases}}" wx:key="index">
        <view class="phase-header"><text class="phase-number">阶段{{index + 1}}</text><view class="delete-btn" bindtap="onDeletePhase" data-index="{{index}}"><text>删除</text></view></view>
        <input class="form-input phase-name" placeholder="阶段名称" placeholder-class="placeholder" value="{{item.name}}" bindinput="onPhaseNameInput" data-index="{{index}}" />
        <textarea class="form-textarea" placeholder="阶段内容描述" placeholder-class="placeholder" value="{{item.content}}" bindinput="onPhaseContentInput" data-index="{{index}}"></textarea>
      </view>
    </view>
    <view class="glass-card">
      <text class="form-label">预算报价（元）</text>
      <input class="form-input" type="digit" placeholder="请输入预算金额" placeholder-class="placeholder" value="{{budget}}" bindinput="onBudgetInput" />
    </view>
    <view class="glass-card">
      <text class="form-label">交付范围</text>
      <text class="sub-label">包含内容</text>
      <view class="tag-list"><view class="tag {{item.selected ? 'active' : ''}}" wx:for="{{inclusions}}" wx:key="index" bindtap="onToggleInclude" data-index="{{index}}"><text>{{item.label}}</text></view></view>
      <text class="sub-label" style="margin-top: 10px;">不包含内容</text>
      <view class="tag-list"><view class="tag {{item.selected ? 'active' : ''}}" wx:for="{{exclusions}}" wx:key="index" bindtap="onToggleExclude" data-index="{{index}}"><text>{{item.label}}</text></view></view>
    </view>
    <view class="action-buttons">
      <button class="btn-primary" bindtap="onPreview">预览方案</button>
      <button class="btn-secondary" bindtap="onSubmit">提交交付</button>
    </view>
    <view style="height: 40px;"></view>
  </scroll-view>
</view>
