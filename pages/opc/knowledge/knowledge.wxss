.page.knowledge { min-height: 100vh; background: #1D1D1F; }
.page-header { padding: 0 20px; margin-top: 12px; margin-bottom: 16px; }
.page-title { font-size: 26px; font-weight: 700; color: rgba(255,255,255,0.85); display: block; line-height: 34px; }
.page-subtitle { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-top: 4px; }

/* Glass search bar */
.search-bar { margin: 0 20px 16px; height: 40px; background: rgba(255,255,255,0.06); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 20px; display: flex; align-items: center; padding: 0 14px; gap: 8px; }
.search-icon { flex-shrink: 0; }
.search-input { flex: 1; height: 100%; font-size: 14px; color: rgba(255,255,255,0.85); }
.placeholder { color: rgba(255,255,255,0.25); font-size: 14px; }

/* Category chips */
.category-chips { padding: 0 20px; margin-bottom: 16px; white-space: nowrap; }
.chip { display: inline-flex; flex-direction: column; align-items: center; padding: 7px 18px 5px; border-radius: 20px; background: rgba(255,255,255,0.05); margin-right: 8px; font-size: 13px; color: rgba(255,255,255,0.5); transition: all 0.3s ease; }
.chip.active { background: rgba(255,159,10,0.12); color: #FF9F0A; font-weight: 600; }
.chip-indicator { height: 2px; width: 0; border-radius: 1px; background: #FF9F0A; margin-top: 4px; transition: width 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
.chip-indicator--active { width: 16px; }

/* Section header */
.section-header { display: flex; justify-content: space-between; align-items: center; padding: 0 20px; margin-bottom: 12px; }
.section-header-left { display: flex; align-items: center; gap: 6px; }
.section-title { font-size: 18px; font-weight: 600; color: rgba(255,255,255,0.85); }

/* Template scroll */
.template-scroll { padding: 0 20px; white-space: nowrap; margin-bottom: 4px; }
.template-card { display: inline-flex; flex-direction: column; width: 150px; background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin-right: 10px; }
.template-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 10px; }
.template-icon-text { font-size: 22px; }
.template-name { font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; margin-bottom: 4px; }
.template-desc { font-size: 11px; color: rgba(255,255,255,0.4); display: block; line-height: 1.4; margin-bottom: 10px; }
.template-action { display: flex; align-items: center; gap: 3px; margin-top: auto; }
.template-action-text { font-size: 11px; color: #FF9F0A; font-weight: 500; }

/* Glass card */
.glass-card { background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin: 0 20px 10px; }

/* Report cards */
.report-header { margin-bottom: 6px; }
.report-title-row { display: flex; gap: 10px; }
.report-type-icon { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,159,10,0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.report-title-content { flex: 1; min-width: 0; }
.report-title { font-size: 15px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; line-height: 1.3; }
.report-date { font-size: 11px; color: rgba(255,255,255,0.3); display: block; margin-top: 1px; }
.report-desc { font-size: 12px; color: rgba(255,255,255,0.5); display: block; margin: 8px 0 10px; line-height: 1.5; }
.report-meta { display: flex; gap: 10px; align-items: center; }
.report-tag { padding: 2px 8px; border-radius: 8px; background: rgba(255,159,10,0.12); font-size: 10px; color: #FF9F0A; font-weight: 500; }
.report-pages { font-size: 11px; color: rgba(255,255,255,0.3); }

/* New template button */
.new-template-section { padding: 8px 20px 0; }
.btn-primary {
  background: linear-gradient(135deg, #FF9F0A 0%, #FFCC02 100%);
  color: #1D1D1F;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  line-height: 48px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
