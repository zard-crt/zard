<view class="page project-detail">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="detail-header">
    <view class="back-btn" bindtap="onBack"><text class="back-arrow">←</text></view>
    <text class="detail-header-title">项目详情</text>
    <view class="header-placeholder"></view>
  </view>
  <scroll-view scroll-y="true" style="height: {{contentHeight}}px;">
    <view class="glass-card project-header-card">
      <text class="project-name-lg">{{project.company}}</text>
      <view class="project-meta-row">
        <view class="status-tag {{project.statusClass}}"><text>{{project.statusText}}</text></view>
        <text class="meta-date">创建: {{project.createDate}}</text>
      </view>
    </view>
    <view class="glass-card progress-overview">
      <text class="section-title">项目进度</text>
      <view class="progress-hero">
        <text class="progress-number">{{project.progress}}%</text>
        <view class="progress-bar-bg hero-bar"><view class="progress-bar-fill" style="width: {{project.progress}}%;"></view></view>
      </view>
      <view class="progress-stats">
        <view class="stat-item"><text class="stat-value">{{project.completedTasks}}</text><text class="stat-label">已完成</text></view>
        <view class="stat-item"><text class="stat-value">{{project.totalTasks - project.completedTasks}}</text><text class="stat-label">进行中</text></view>
        <view class="stat-item"><text class="stat-value">{{project.members.length}}</text><text class="stat-label">成员</text></view>
      </view>
    </view>
    <view class="glass-card members-section">
      <text class="section-title">参与成员</text>
      <view class="member-list">
        <view class="member-item" wx:for="{{project.members}}" wx:key="index">
          <view class="member-avatar"><text class="avatar-text">{{item.name[0]}}</text></view>
          <view class="member-info"><text class="member-name">{{item.name}}</text><text class="member-role">{{item.role}}</text></view>
          <view class="member-status {{item.done ? 'done' : 'pending'}}"><text>{{item.done ? '已完成' : '待完成'}}</text></view>
        </view>
      </view>
    </view>
    <view class="glass-card diagnosis-section">
      <text class="section-title">诊断结果</text>
      <view class="finding-item" wx:for="{{project.findings}}" wx:key="index">
        <view class="finding-priority {{item.priority}}"></view>
        <view class="finding-content"><text class="finding-title">{{item.title}}</text><text class="finding-desc">{{item.description}}</text></view>
        <text class="finding-score">严重度 {{item.severity}}/10</text>
      </view>
    </view>
    <view class="action-buttons">
      <button class="btn-primary" bindtap="onReview">进入评审</button>
      <button class="btn-secondary" bindtap="onViewPlan">查看方案</button>
    </view>
    <view style="height: 40px;"></view>
  </scroll-view>
</view>
