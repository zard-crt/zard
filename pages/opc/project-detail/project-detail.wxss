.page.project-detail { min-height: 100vh; background: #1D1D1F; }

/* Header */
.detail-header { display: flex; align-items: center; padding: 0 20px 12px; justify-content: space-between; }
.back-btn { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 18px; background: rgba(255,255,255,0.06); transition: background 0.2s; }
.back-btn:active { background: rgba(255,255,255,0.12); }
.detail-header-title { font-size: 17px; font-weight: 600; color: rgba(255,255,255,0.85); }
.header-placeholder { width: 36px; }

/* Glass card */
.glass-card { background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin: 0 20px 12px; }

/* Header Card */
.project-header-card { padding: 16px; }
.header-company-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.company-badge { width: 42px; height: 42px; border-radius: 21px; background: linear-gradient(135deg, #FF9F0A, #FFCC02); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.company-badge-text { font-size: 18px; font-weight: 700; color: #1D1D1F; }
.header-company-info { flex: 1; }
.project-name-lg { font-size: 20px; font-weight: 700; color: rgba(255,255,255,0.85); display: block; margin-bottom: 2px; }
.project-industry { font-size: 13px; color: rgba(255,255,255,0.4); }
.header-meta-row { display: flex; align-items: center; justify-content: space-between; padding-top: 10px; border-top: 0.5px solid rgba(255,255,255,0.06); }
.meta-item { display: flex; align-items: center; gap: 4px; }
.meta-text { font-size: 12px; color: rgba(255,255,255,0.4); }
.status-tag { padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 500; }
.status-tag.ongoing { background: rgba(255,159,10,0.15); color: #FF9F0A; }
.status-tag.completed { background: rgba(52,199,89,0.15); color: #34C759; }

/* Section */
.section-title { font-size: 16px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; margin-bottom: 12px; }

/* Progress Circle */
.progress-hero-row { display: flex; align-items: center; gap: 16px; margin: 12px 0 16px; }
.progress-circle-wrap { position: relative; width: 80px; height: 80px; flex-shrink: 0; }
.progress-circle { display: block; }
.progress-circle-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 18px; font-weight: 800; color: #FF9F0A; }
.progress-stats-col { display: flex; flex-direction: column; gap: 6px; flex: 1; }
.progress-stat-item { display: flex; align-items: center; gap: 8px; }
.progress-stat-value { font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.85); min-width: 24px; }
.progress-stat-label { font-size: 12px; color: rgba(255,255,255,0.4); }

/* Progress Bar */
.progress-bar-section { margin-top: 4px; }
.progress-bar-bg { height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
.progress-bar-fill { height: 100%; background: linear-gradient(90deg, #FF9F0A, #FFCC02); border-radius: 2px; transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1); }
.progress-bar-labels { display: flex; justify-content: space-between; margin-top: 4px; }
.progress-bar-labels text { font-size: 10px; color: rgba(255,255,255,0.2); }

/* Members */
.member-list { margin-top: 6px; }
.member-item { display: flex; align-items: center; padding: 10px 0; border-bottom: 0.5px solid rgba(255,255,255,0.05); }
.member-item:last-child { border-bottom: none; }
.member-avatar { width: 36px; height: 36px; border-radius: 18px; display: flex; align-items: center; justify-content: center; margin-right: 10px; flex-shrink: 0; }
.avatar-text { font-size: 14px; font-weight: 600; }
.member-info { flex: 1; }
.member-name { font-size: 14px; color: rgba(255,255,255,0.85); display: block; }
.member-role { font-size: 11px; color: rgba(255,255,255,0.4); display: block; margin-top: 2px; }
.member-status { padding: 3px 8px; border-radius: 10px; font-size: 11px; }
.status-inner { display: flex; align-items: center; gap: 3px; }
.member-status.done { background: rgba(52,199,89,0.12); color: #34C759; }
.member-status.pending { background: rgba(255,159,10,0.12); color: #FF9F0A; }

/* Findings */
.finding-item { display: flex; align-items: flex-start; padding: 12px 0; border-bottom: 0.5px solid rgba(255,255,255,0.05); gap: 10px; }
.finding-item:last-child { border-bottom: none; }
.finding-priority { width: 20px; flex-shrink: 0; padding-top: 2px; }
.priority-dot { width: 8px; height: 8px; border-radius: 4px; }
.priority-dot.high { background: #FF3B30; box-shadow: 0 0 6px rgba(255,59,48,0.4); }
.priority-dot.medium { background: #FF9F0A; box-shadow: 0 0 6px rgba(255,159,10,0.4); }
.priority-dot.low { background: #34C759; box-shadow: 0 0 6px rgba(52,199,89,0.4); }
.finding-content { flex: 1; }
.finding-title { font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; }
.finding-desc { font-size: 12px; color: rgba(255,255,255,0.5); display: block; margin-top: 2px; line-height: 1.4; }
.finding-score { padding: 2px 8px; border-radius: 8px; font-size: 11px; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
.finding-score.high { background: rgba(255,59,48,0.12); color: #FF3B30; }
.finding-score.medium { background: rgba(255,159,10,0.12); color: #FF9F0A; }
.finding-score.low { background: rgba(52,199,89,0.12); color: #34C759; }

/* Action buttons */
.action-buttons { padding: 8px 20px 0; display: flex; flex-direction: column; gap: 10px; }
.btn-primary {
  background: linear-gradient(135deg, #FF9F0A 0%, #FFCC02 100%);
  color: #1D1D1F;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  line-height: 48px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.btn-primary::after { border: none; }
.btn-primary:active { opacity: 0.9; transform: scale(0.98); }
.btn-secondary {
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.8);
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  height: 48px;
  line-height: 48px;
  border: 0.5px solid rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.btn-secondary::after { border: none; }
.btn-secondary:active { background: rgba(255,255,255,0.1); }
