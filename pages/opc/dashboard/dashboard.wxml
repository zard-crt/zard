<view class="page dashboard">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="page-header">
    <text class="page-title">数据</text>
    <text class="page-subtitle">平台运营概览</text>
  </view>
  <scroll-view scroll-y="true" style="height: {{contentHeight}}px;">
    <!-- Stat Cards -->
    <!-- DeepSeek Config Button -->
    <view class="deepseek-config" bindtap="onDeepseekConfig">
      <svg viewBox="0 0 20 20" width="14" height="14">
        <path d="M10 2a8 8 0 100 16 8 8 0 000-16zm0 14a6 6 0 110-12 6 6 0 010 12z" stroke="rgba(255,255,255,0.5)" stroke-width="1.2" fill="none"/>
        <path d="M10 6v4M10 13v1" stroke="#FF9F0A" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <text class="deepseek-config-text">DeepSeek 配置</text>
      <view class="deepseek-status {{deepseekConfigured ? 'configured' : ''}}">
        <text>{{deepseekConfigured ? '已配置' : '未配置'}}</text>
      </view>
    </view>
    
    <!-- DeepSeek Config Modal -->
    <view wx:if="{{showDeepseekModal}}" class="ds-modal-overlay" bindtap="onDsModalClose">
      <view class="ds-modal" catchtap="">
        <text class="ds-modal-title">DeepSeek V4 Pro Fast 配置</text>
        <text class="ds-modal-desc">输入 API Key 即可启用 AI 对话和诊断分析</text>
        <input class="ds-input" type="text" placeholder="sk-xxxxxxxxxxxxxxxx" placeholder-class="ds-placeholder" value="{{deepseekKey}}" bindinput="onDsKeyInput" />
        <view class="ds-modal-actions">
          <view class="ds-btn ds-btn-cancel" bindtap="onDsModalClose">取消</view>
          <view class="ds-btn ds-btn-save" bindtap="onDsSave">保存</view>
        </view>
        <text wx:if="{{dsConfigStatus}}" class="ds-status {{dsConfigStatusType}}">{{dsConfigStatus}}</text>
      </view>
    </view>
    
    <view class="stat-row">
      <view class="stat-card-wrap">
        <view class="stat-card-bg"></view>
        <view class="stat-card">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
            <circle cx="12" cy="12" r="9" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
            <path d="M12 8v4l3 3" stroke="#FF9F0A" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <text class="stat-number">{{stats.ongoing}}</text>
          <text class="stat-label">进行中</text>
        </view>
      </view>
      <view class="stat-card-wrap">
        <view class="stat-card-bg stat-card-bg--orange"></view>
        <view class="stat-card">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
            <path d="M12 4v16M4 12h16" stroke="#FF9F0A" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <text class="stat-number orange">{{stats.newThisMonth}}</text>
          <text class="stat-label">本月新增</text>
        </view>
      </view>
      <view class="stat-card-wrap">
        <view class="stat-card-bg stat-card-bg--green"></view>
        <view class="stat-card">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
            <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke="#34C759" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <text class="stat-number green">{{stats.conversionRate}}%</text>
          <text class="stat-label">转化率</text>
        </view>
      </view>
    </view>
    <!-- Bar Chart -->
    <view class="glass-card chart-section">
      <view class="section-header-row">
        <text class="section-title">本周新增</text>
        <text class="section-more">查看详情</text>
      </view>
      <view class="bar-chart">
        <view class="bar-item" wx:for="{{weeklyData}}" wx:key="index">
          <view class="bar-container">
            <view class="bar-fill" style="height: {{animatedBars[index]}}%;"></view>
          </view>
          <text class="bar-label">{{item.day}}</text>
        </view>
      </view>
    </view>
    <!-- Industry Distribution -->
    <view class="glass-card industry-section">
      <view class="section-header-row">
        <text class="section-title">行业分布</text>
        <text class="section-more">全部行业</text>
      </view>
      <view class="industry-item" wx:for="{{industries}}" wx:key="index">
        <view class="industry-header">
          <view class="industry-left">
            <view class="industry-dot" style="background: {{item.color}};"></view>
            <text class="industry-name">{{item.name}}</text>
          </view>
          <text class="industry-count">{{item.count}}个</text>
        </view>
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{item.percent}}%; background: linear-gradient(90deg, {{item.color}}, {{item.color}}88);"></view>
        </view>
        <text class="industry-percent">{{item.percent}}%</text>
      </view>
    </view>
    <!-- Pending Items -->
    <view class="glass-card pending-section">
      <view class="section-header-row">
        <text class="section-title">待处理</text>
      </view>
      <view class="pending-item" wx:for="{{pendingItems}}" wx:key="index" bindtap="onPendingTap" data-url="{{item.url}}">
        <view class="pending-left">
          <view class="pending-count-badge">{{item.count}}</view>
          <text class="pending-title">{{item.title}}</text>
        </view>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none">
          <path d="M9 6l6 6-6 6" stroke="rgba(255,255,255,0.25)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </view>
    </view>
    <view style="height: 80px;"></view>
  </scroll-view>
  <tab-bar type="opc" active="2" bind:tap="onTabTap"></tab-bar>
</view>
