.page.dashboard { min-height: 100vh; background: #1D1D1F; }
.page-header { padding: 0 20px; margin-top: 12px; margin-bottom: 20px; }
.page-title { font-size: 26px; font-weight: 700; color: rgba(255,255,255,0.85); display: block; line-height: 34px; }
.page-subtitle { font-size: 13px; color: rgba(255,255,255,0.5); display: block; margin-top: 4px; }

/* Glass card */
.glass-card { background: rgba(30,30,32,0.65); backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px); border: 0.5px solid rgba(255,255,255,0.08); border-radius: 14px; padding: 14px; margin: 0 20px 12px; }

/* Section header */
.section-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.section-title { font-size: 16px; font-weight: 600; color: rgba(255,255,255,0.85); }
.section-more { font-size: 12px; color: #FF9F0A; font-weight: 500; }

/* Stat cards with gradient borders */
.stat-row { display: flex; gap: 8px; padding: 0 20px; margin-bottom: 12px; }
.stat-card-wrap { flex: 1; position: relative; border-radius: 14px; overflow: hidden; }
.stat-card-bg { position: absolute; inset: 0; border-radius: 14px; padding: 1px; background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02)); }
.stat-card-bg--orange { background: linear-gradient(135deg, rgba(255,159,10,0.3), rgba(255,159,10,0.05)); }
.stat-card-bg--green { background: linear-gradient(135deg, rgba(52,199,89,0.3), rgba(52,199,89,0.05)); }
.stat-card {
  position: relative;
  background: rgba(30,30,32,0.85);
  border-radius: 13px;
  padding: 12px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  margin: 1px;
}
.stat-number { font-size: 22px; font-weight: 800; color: rgba(255,255,255,0.85); display: block; line-height: 1.1; }
.stat-number.orange { color: #FF9F0A; }
.stat-number.green { color: #34C759; }
.stat-label { font-size: 11px; color: rgba(255,255,255,0.4); display: block; text-align: center; }

/* Bar chart */
.bar-chart { display: flex; justify-content: space-between; align-items: flex-end; padding: 0 4px; }
.bar-item { display: flex; flex-direction: column; align-items: center; gap: 6px; flex: 1; }
.bar-container { width: 24px; height: 100px; background: rgba(255,255,255,0.04); border-radius: 12px; position: relative; overflow: hidden; }
.bar-fill { position: absolute; bottom: 0; width: 100%; background: linear-gradient(180deg, #FF9F0A, #FFCC02); border-radius: 12px; transition: height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); }
.bar-label { font-size: 11px; color: rgba(255,255,255,0.35); }

/* Industry */
.industry-item { margin-bottom: 14px; }
.industry-item:last-child { margin-bottom: 0; }
.industry-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.industry-left { display: flex; align-items: center; gap: 6px; }
.industry-dot { width: 6px; height: 6px; border-radius: 3px; }
.industry-name { font-size: 13px; color: rgba(255,255,255,0.7); }
.industry-count { font-size: 12px; color: rgba(255,255,255,0.35); }
.progress-bar-bg { height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; margin-bottom: 3px; }
.progress-bar-fill { height: 100%; border-radius: 2px; transition: width 0.6s ease; }
.industry-percent { font-size: 10px; color: rgba(255,255,255,0.25); display: block; text-align: right; }

/* Pending items */
.pending-item { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 0.5px solid rgba(255,255,255,0.05); }
.pending-item:last-child { border-bottom: none; }
.pending-left { display: flex; align-items: center; gap: 10px; }
.pending-count-badge { width: 24px; height: 24px; border-radius: 12px; background: rgba(255,159,10,0.15); color: #FF9F0A; font-size: 12px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.pending-title { font-size: 14px; color: rgba(255,255,255,0.85); font-weight: 500; }

/* ===== DeepSeek Config ===== */
.deepseek-config {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  margin: 0 20px 12px;
  background: rgba(30,30,32,0.65);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border: 0.5px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  cursor: pointer;
}
.deepseek-config:active { transform: scale(0.98); }
.deepseek-config-text { flex: 1; font-size: 13px; color: rgba(255,255,255,0.6); }
.deepseek-status { padding: 2px 10px; border-radius: 10px; font-size: 10px; background: rgba(255,59,48,0.15); color: #FF3B30; }
.deepseek-status.configured { background: rgba(52,199,89,0.15); color: #34C759; }

/* Modal */
.ds-modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 2000;
  display: flex; align-items: center; justify-content: center;
}
.ds-modal {
  width: 320px; background: rgba(30,30,32,0.95);
  backdrop-filter: blur(60px); -webkit-backdrop-filter: blur(60px);
  border: 0.5px solid rgba(255,255,255,0.1);
  border-radius: 20px; padding: 24px;
}
.ds-modal-title { font-size: 17px; font-weight: 600; color: rgba(255,255,255,0.85); display: block; margin-bottom: 6px; text-align: center; }
.ds-modal-desc { font-size: 12px; color: rgba(255,255,255,0.4); display: block; margin-bottom: 16px; text-align: center; }
.ds-input {
  width: 100%; height: 44px;
  background: rgba(255,255,255,0.06); border-radius: 10px;
  padding: 0 14px; font-size: 14px; color: rgba(255,255,255,0.85);
  box-sizing: border-box; text-align: center;
}
.ds-placeholder { color: rgba(255,255,255,0.2); font-size: 14px; }
.ds-modal-actions { display: flex; gap: 10px; margin-top: 16px; }
.ds-btn { flex: 1; text-align: center; padding: 12px; border-radius: 10px; font-size: 14px; font-weight: 500; }
.ds-btn-cancel { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); }
.ds-btn-save { background: #FF9F0A; color: #1D1D1F; font-weight: 600; }
.ds-status { display: block; text-align: center; font-size: 12px; margin-top: 10px; }
.ds-status.success { color: #34C759; }
.ds-status.error { color: #FF3B30; }
