/* report.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.title-section {
  padding: 16px 0 4px;
}

.page-title {
  font-size: 26px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  line-height: 1.3;
}

.section {
  padding: 12px 0;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  margin-bottom: 12px;
}

/* Company Card */
.company-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.company-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.company-logo {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.company-logo-text {
  font-size: 18px;
  font-weight: bold;
  color: #FFFFFF;
}

.company-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.company-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.company-date {
  font-size: 12px;
  color: #86868B;
}

.company-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.score-number {
  font-size: 22px;
  font-weight: bold;
  color: #0071E3;
}

.score-label {
  font-size: 11px;
  color: #86868B;
}

/* Heatmap */
.heatmap-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  overflow-x: auto;
}

.heatmap-grid {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.heatmap-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.heatmap-header {
  margin-bottom: 4px;
}

.heatmap-cell-label {
  width: 60px;
  flex-shrink: 0;
}

.heatmap-label-text {
  font-size: 12px;
  color: #86868B;
  font-weight: 500;
}

.heatmap-header-text {
  font-size: 11px;
  color: #86868B;
  text-align: center;
  font-weight: 500;
}

.heatmap-cell-header {
  flex: 1;
  text-align: center;
  min-width: 52px;
}

.heatmap-cell {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  min-width: 52px;
  padding: 4px 0;
}

.heatmap-dot {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.heatmap-dot-high {
  background-color: #FF3B30;
}

.heatmap-dot-medium {
  background-color: #FF9500;
}

.heatmap-dot-low {
  background-color: #34C759;
}

.heatmap-dot-text {
  font-size: 12px;
  font-weight: 600;
  color: #FFFFFF;
}

/* Key Findings */
.findings-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.finding-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.finding-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.finding-icon-purple {
  background-color: rgba(175, 82, 222, 0.12);
}

.finding-icon-orange {
  background-color: rgba(255, 149, 0, 0.12);
}

.finding-icon-blue {
  background-color: rgba(0, 113, 227, 0.12);
}

.finding-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.finding-label {
  font-size: 12px;
  color: #86868B;
}

.finding-value {
  font-size: 16px;
  font-weight: 600;
  color: #1D1D1F;
}

.finding-desc {
  font-size: 12px;
  color: #86868B;
  margin-top: 1px;
}

.tabbar-spacer {
  width: 100%;
}
