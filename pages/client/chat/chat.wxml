<!-- chat.wxml v3 - 对话页 (带角色指示) -->
<view class="page">
  <!-- Status bar spacer -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- Nav bar with haptic-like feedback and role indicator -->
  <view class="nav-bar glass-strong">
    <view class="nav-back press-scale" bindtap="onBack">
      <svg viewBox="0 0 24 24" width="24" height="24">
        <path d="M15 18l-6-6 6-6" stroke="#0071E3" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </view>
    <view class="nav-title-group">
      <text class="nav-title">AI诊断对话</text>
      <text class="nav-role" wx:if="{{roleName}}">{{roleIcon}} {{roleName}}卷</text>
    </view>
    <view class="nav-placeholder"></view>
  </view>
  
  <!-- Progress indicator with counter -->
  <view class="progress-indicator">
    <view class="progress-top">
      <text class="progress-label">第{{currentQuestion}}题 / 共{{totalQuestions}}题</text>
      <text class="progress-percent">{{Math.round(currentQuestion / totalQuestions * 100)}}%</text>
    </view>
    <view class="progress-track">
      <view class="progress-fill slide-up" style="width: {{(currentQuestion / totalQuestions) * 100}}%;"></view>
    </view>
  </view>
  
  <!-- Message area -->
  <scroll-view class="message-area" scroll-y="{{true}}" scroll-into-view="{{lastMsgId}}" scroll-with-animation="{{true}}" upper-threshold="50">
    <view class="message-list">
      <view class="message-item message-{{msg.type}}" wx:for="{{messages}}" wx:for-item="msg" wx:key="index" id="msg-{{index}}">
        <!-- AI message -->
        <block wx:if="{{msg.type === 'ai'}}">
          <view class="ai-avatar">
            <svg viewBox="0 0 24 24" width="16" height="16">
              <circle cx="12" cy="12" r="10" stroke="#0071E3" stroke-width="1.5" fill="none"/>
              <path d="M12 8v4M12 16h0" stroke="#0071E3" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </view>
          <view class="ai-bubble">
            <text class="ai-text">{{msg.content}}</text>
          </view>
          <view wx:if="{{msg.choices && msg.choices.length > 0}}" class="choice-group">
            <view class="choice-btn" wx:for="{{msg.choices}}" wx:for-item="choice" wx:key="index" bindtap="onChoiceTap" data-value="{{choice.value}}">
              <text class="choice-text">{{choice.label}}</text>
              <svg viewBox="0 0 20 20" width="16" height="16" class="choice-arrow">
                <path d="M7 4l6 6-6 6" stroke="#0071E3" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </view>
          </view>
        </block>
        
        <!-- Typing indicator -->
        <block wx:elif="{{msg.type === 'typing'}}">
          <view class="ai-bubble typing-bubble">
            <view class="typing-dots">
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
              <view class="typing-dot"></view>
            </view>
          </view>
        </block>
        
        <!-- User message -->
        <block wx:elif="{{msg.type === 'user'}}">
          <view class="user-bubble">
            <text class="user-text">{{msg.content}}</text>
          </view>
        </block>
        
        <!-- System message -->
        <block wx:elif="{{msg.type === 'system'}}">
          <view class="system-msg">
            <svg viewBox="0 0 16 16" width="14" height="14" class="system-msg-icon">
              <circle cx="8" cy="8" r="7" stroke="#86868B" stroke-width="1.2" fill="none"/>
              <path d="M8 5v4M8 11h0" stroke="#86868B" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <text class="system-text">{{msg.content}}</text>
          </view>
        </block>
      </view>
    </view>
  </scroll-view>
  
  <!-- Bottom input bar -->
  <view class="input-bar glass-strong">
    <view class="input-container">
      <input class="chat-input" type="text" placeholder="输入你的回答..." placeholder-style="color: #86868B" value="{{inputValue}}" bindinput="onInputChange" bindconfirm="onSend" focus="{{inputFocused}}" />
      <view class="send-btn {{inputValue.trim() ? 'send-active' : ''}}" bindtap="onSend">
        <svg viewBox="0 0 24 24" width="20" height="20">
          <path d="M5 12h14M12 5l7 7-7 7" stroke="{{inputValue.trim() ? '#FFFFFF' : '#C7C7CC'}}" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </view>
    </view>
  </view>
</view>
