/* chat.wxss v2 - 对话页 */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* ========== Nav Bar ========== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 4px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-back {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-back:active {
  background: rgba(0, 113, 227, 0.08);
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
}

.nav-placeholder {
  width: 44px;
}

/* ========== Progress Indicator ========== */
.progress-indicator {
  padding: 6px 20px 10px;
  animation: slideUp 0.3s cubic-bezier(0.0, 0.0, 0.2, 1) both;
}

.progress-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.progress-label {
  font-size: 13px;
  color: #86868B;
}

.progress-percent {
  font-size: 13px;
  font-weight: 600;
  color: #0071E3;
}

.progress-track {
  height: 4px;
  background-color: #E8E8ED;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4B9EFF);
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ========== Message Area ========== */
.message-area {
  flex: 1;
  padding: 0 20px;
  overflow-y: auto;
}

.message-list {
  padding: 12px 0;
}

.message-item {
  margin-bottom: 14px;
  opacity: 0;
  animation: msgIn 0.35s cubic-bezier(0.0, 0.0, 0.2, 1) forwards;
}

/* Staggered delay for each message */
.message-item:nth-child(1) { animation-delay: 0ms; }
.message-item:nth-child(2) { animation-delay: 50ms; }
.message-item:nth-child(3) { animation-delay: 100ms; }
.message-item:nth-child(4) { animation-delay: 150ms; }
.message-item:nth-child(5) { animation-delay: 200ms; }
.message-item:nth-child(6) { animation-delay: 250ms; }
.message-item:nth-child(7) { animation-delay: 300ms; }
.message-item:nth-child(8) { animation-delay: 350ms; }
.message-item:nth-child(9) { animation-delay: 400ms; }
.message-item:nth-child(10) { animation-delay: 450ms; }

@keyframes msgIn {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== AI Bubble ========== */
.message-ai {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.ai-avatar {
  width: 24px;
  height: 24px;
  background: rgba(0, 113, 227, 0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4px;
}

.ai-bubble {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 12px 16px;
  max-width: 85%;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.ai-text {
  font-size: 15px;
  color: #1D1D1F;
  line-height: 1.6;
}

/* ========== Typing Bubble ========== */
.typing-bubble {
  padding: 14px 18px;
}

/* ========== Choice Buttons ========== */
.choice-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 10px;
  width: 100%;
  animation: slideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.choice-btn {
  background-color: #FFFFFF;
  border: 1.5px solid rgba(0, 113, 227, 0.2);
  border-radius: 12px;
  padding: 12px 16px;
  max-width: 85%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.choice-btn:active {
  background-color: #0071E3;
  border-color: #0071E3;
  transform: scale(0.97);
}

.choice-btn:active .choice-text {
  color: #FFFFFF;
}

.choice-btn:active .choice-arrow path {
  stroke: #FFFFFF;
}

.choice-text {
  font-size: 15px;
  color: #0071E3;
  line-height: 1.4;
  font-weight: 500;
  flex: 1;
}

.choice-arrow {
  flex-shrink: 0;
  margin-left: 4px;
}

.choice-arrow path {
  transition: stroke 0.2s;
}

/* ========== User Bubble ========== */
.message-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.user-bubble {
  background: linear-gradient(135deg, #0071E3, #4B9EFF);
  border-radius: 14px;
  padding: 12px 16px;
  max-width: 75%;
  border-bottom-right-radius: 4px;
  box-shadow: 0 2px 8px rgba(0, 113, 227, 0.15);
}

.user-text {
  font-size: 15px;
  color: #FFFFFF;
  line-height: 1.5;
}

/* ========== System Message ========== */
.message-system {
  display: flex;
  justify-content: center;
}

.system-msg {
  display: flex;
  align-items: center;
  gap: 6px;
  background-color: rgba(134, 134, 139, 0.06);
  padding: 8px 16px;
  border-radius: 20px;
}

.system-msg-icon {
  flex-shrink: 0;
}

.system-text {
  font-size: 12px;
  color: #86868B;
  line-height: 1.4;
}

/* ========== Input Bar ========== */
.input-bar {
  padding: 8px 20px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
  position: sticky;
  bottom: 0;
  z-index: 10;
}

.input-container {
  display: flex;
  align-items: center;
  background-color: rgba(240, 240, 242, 0.8);
  border-radius: 12px;
  padding: 4px 4px 4px 16px;
  border: 0.5px solid rgba(0, 0, 0, 0.04);
}

.chat-input {
  flex: 1;
  height: 38px;
  font-size: 15px;
  color: #1D1D1F;
}

.send-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #E5E5EA;
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.send-active {
  background-color: #0071E3;
  box-shadow: 0 2px 8px rgba(0, 113, 227, 0.25);
}

.send-active:active {
  transform: scale(0.92);
}
