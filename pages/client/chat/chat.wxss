/* chat.wxss */
.page {
  min-height: 100vh;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* Nav Bar */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 4px;
}

.nav-back {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
}

.nav-placeholder {
  width: 44px;
}

/* Progress Indicator */
.progress-indicator {
  padding: 8px 20px 12px;
}

.progress-label {
  font-size: 13px;
  color: #86868B;
  display: block;
  margin-bottom: 6px;
}

.progress-track {
  height: 4px;
  background-color: #F0F0F2;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4A9EFF);
  border-radius: 2px;
  transition: width 0.3s ease;
}

/* Message Area */
.message-area {
  flex: 1;
  padding: 0 20px;
  overflow-y: auto;
}

.message-list {
  padding: 12px 0;
}

.message-item {
  margin-bottom: 12px;
  opacity: 0;
  animation: slideUp 0.3s ease forwards;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* AI Bubble */
.message-ai {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.ai-bubble {
  background-color: #F0F0F2;
  border-radius: 14px;
  padding: 12px 16px;
  max-width: 85%;
  border-bottom-left-radius: 4px;
}

.ai-text {
  font-size: 15px;
  color: #1D1D1F;
  line-height: 1.5;
}

/* Choice Buttons */
.choice-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 10px;
  width: 100%;
}

.choice-btn {
  background-color: #FFFFFF;
  border: 1.5px solid #0071E3;
  border-radius: 12px;
  padding: 12px 16px;
  max-width: 85%;
}

.choice-text {
  font-size: 15px;
  color: #0071E3;
  line-height: 1.4;
}

/* User Bubble */
.message-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.user-bubble {
  background-color: #0071E3;
  border-radius: 14px 14px 4px 14px;
  padding: 12px 16px;
  max-width: 85%;
}

.user-text {
  font-size: 15px;
  color: #FFFFFF;
  line-height: 1.5;
}

/* System Message */
.message-system {
  display: flex;
  justify-content: center;
}

.system-msg {
  background-color: #F5F5F7;
  border-radius: 10px;
  padding: 6px 14px;
}

.system-text {
  font-size: 12px;
  color: #86868B;
}

/* Input Bar */
.input-bar {
  padding: 8px 20px;
  padding-bottom: calc(8px + env(safe-area-inset-bottom, 0px));
  background-color: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 0.5px solid rgba(0, 0, 0, 0.06);
}

.input-container {
  display: flex;
  align-items: center;
  background-color: #F0F0F2;
  border-radius: 10px;
  padding: 4px 4px 4px 14px;
}

.chat-input {
  flex: 1;
  height: 36px;
  font-size: 15px;
  color: #1D1D1F;
}

.send-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #E5E5EA;
  flex-shrink: 0;
}

.send-active {
  background-color: #0071E3;
}
