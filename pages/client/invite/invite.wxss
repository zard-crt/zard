/* invite.wxss v2 - 邀请页 */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* ========== Nav Bar ========== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 4px;
  margin-bottom: 8px;
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-back {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
}

.nav-placeholder {
  width: 44px;
}

/* ========== Project Card ========== */
.project-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  margin-bottom: 8px;
}

.project-row {
  display: flex;
  align-items: center;
  gap: 12px;
}

.project-logo {
  width: 42px;
  height: 42px;
  border-radius: 11px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.project-logo-text {
  font-size: 17px;
  font-weight: 700;
  color: #FFFFFF;
}

.project-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.project-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.project-status {
  font-size: 13px;
  color: #86868B;
}

/* ========== Section ========== */
.section {
  padding: 12px 0;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  margin-bottom: 12px;
}

/* ========== Member List ========== */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.member-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s cubic-bezier(0.0, 0.0, 0.2, 1);
}

.member-card:active {
  transform: scale(0.98);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

.member-card-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.member-avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.member-avatar-text {
  font-size: 14px;
  font-weight: 600;
  color: #FFFFFF;
}

.member-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.member-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.member-role {
  font-size: 12px;
  color: #86868B;
}

/* ========== Invite Action ========== */
.invite-action {
  padding: 6px 16px;
  border-radius: 10px;
  background-color: #0071E3;
  flex-shrink: 0;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.invite-action-text {
  font-size: 13px;
  font-weight: 600;
  color: #FFFFFF;
}

.invite-action.invited {
  background-color: #F0F0F2;
}
.invite-action.invited .invite-action-text {
  color: #86868B;
}

/* ========== Share Options ========== */
.share-options {
  display: flex;
  gap: 12px;
}

.share-btn {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 20px 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.share-icon {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-icon {
  background: linear-gradient(135deg, rgba(52, 199, 89, 0.15), rgba(52, 199, 89, 0.05));
}

.code-icon {
  background: linear-gradient(135deg, rgba(0, 113, 227, 0.15), rgba(0, 113, 227, 0.05));
}

.share-label {
  font-size: 14px;
  font-weight: 600;
  color: #1D1D1F;
}

.share-desc {
  font-size: 11px;
  color: #86868B;
}

/* ========== Invite Code Modal ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s cubic-bezier(0.0, 0.0, 0.2, 1) both;
}

.modal-content {
  width: 300px;
  border-radius: 20px;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.modal-handle {
  width: 36px;
  height: 4px;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 2px;
  margin-bottom: 16px;
}

.modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1D1D1F;
  margin-bottom: 16px;
}

.code-display {
  background: #F5F5F7;
  border-radius: 12px;
  padding: 14px 24px;
  margin-bottom: 12px;
  border: 1px dashed rgba(0, 113, 227, 0.3);
}

.code-text {
  font-size: 28px;
  font-weight: 800;
  letter-spacing: 4px;
  color: #0071E3;
}

.modal-desc {
  font-size: 13px;
  color: #86868B;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 20px;
}

.copy-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  background: #0071E3;
}

.copy-btn-text {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.modal-close {
  margin-top: 12px;
  padding: 8px 24px;
}

.modal-close-text {
  font-size: 14px;
  color: #86868B;
  font-weight: 500;
}

/* ========== Invited Members (Timeline) ========== */
.invited-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-left: 8px;
  position: relative;
}

.invited-item {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  margin-bottom: 8px;
  position: relative;
}

.timeline-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #0071E3;
  flex-shrink: 0;
  border: 2px solid rgba(0, 113, 227, 0.15);
}

.invited-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}

.invited-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.invited-avatar-text {
  font-size: 12px;
  font-weight: 600;
  color: #FFFFFF;
}

.invited-details {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.invited-name {
  font-size: 14px;
  font-weight: 600;
  color: #1D1D1F;
}

.invited-time {
  font-size: 11px;
  color: #86868B;
}

.invited-status-tag {
  display: flex;
  align-items: center;
  gap: 3px;
  flex-shrink: 0;
}

.invited-status-text {
  font-size: 12px;
  color: #30D158;
  font-weight: 500;
}

.empty-invited {
  padding: 24px 0;
  display: flex;
  justify-content: center;
}

.empty-invited-text {
  font-size: 14px;
  color: #C7C7CC;
}

.tabbar-spacer {
  width: 100%;
}
