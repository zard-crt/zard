<!-- invite.wxml -->
<view class="page">
  <!-- Status bar spacer -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- Nav bar -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <svg viewBox="0 0 24 24" width="24" height="24">
        <path d="M15 18l-6-6 6-6" stroke="#0071E3" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </view>
    <text class="nav-title">邀请成员</text>
    <view class="nav-placeholder"></view>
  </view>
  
  <!-- Project Card -->
  <view class="project-card">
    <view class="project-row">
      <view class="project-logo" style="background-color: {{project.color}};">
        <text class="project-logo-text">{{project.logoText}}</text>
      </view>
      <view class="project-details">
        <text class="project-name">{{project.name}}</text>
        <text class="project-status">诊断项目 · {{project.status}}</text>
      </view>
    </view>
  </view>
  
  <!-- Recommend Members Section -->
  <view class="section">
    <text class="section-title">推荐邀请</text>
    <view class="member-list">
      <view class="member-card" wx:for="{{recommendMembers}}" wx:for-item="member" wx:key="index">
        <view class="member-card-left">
          <view class="member-avatar" style="background-color: {{member.color}};">
            <text class="member-avatar-text">{{member.initials}}</text>
          </view>
          <view class="member-details">
            <text class="member-name">{{member.name}}</text>
            <text class="member-role">{{member.role}} · {{member.department}}</text>
          </view>
        </view>
        <view class="invite-action {{member.invited ? 'invited' : ''}}" bindtap="onInviteMember" data-id="{{member.id}}">
          <text class="invite-action-text">{{member.invited ? '已邀请' : '邀请'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- Share Section -->
  <view class="section">
    <text class="section-title">分享邀请</text>
    <view class="share-options">
      <view class="share-btn" bindtap="onShareWechat">
        <view class="share-icon wechat-icon">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path d="M9 4C5.5 4 2.5 6.5 2.5 9.5c0 1.7.9 3.2 2.3 4.2l-.7 2.1 2.4-1.2c.7.2 1.4.3 2.1.3.3 0 .6 0 .9-.1" stroke="#34C759" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M15 14c3 0 5.5-2 5.5-4.5S18 5 15 5c-3 0-5.5 2.2-5.5 4.8 0 1.9 1.1 3.6 2.8 4.5l-.5 1.5 2.3-1.1c.2 0 .5.1.7.1.3 0 .5 0 .7-.2M7.5 7h.1M11.5 7h.1" stroke="#34C759" stroke-width="1.8" fill="none" stroke-linecap="round"/>
          </svg>
        </view>
        <text class="share-label">分享给微信好友</text>
      </view>
      <view class="share-btn" bindtap="onGenerateCode">
        <view class="share-icon code-icon">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <rect x="3" y="3" width="7" height="7" rx="1.5" stroke="#0071E3" stroke-width="1.8" fill="none"/>
            <rect x="14" y="3" width="7" height="7" rx="1.5" stroke="#0071E3" stroke-width="1.8" fill="none"/>
            <rect x="3" y="14" width="7" height="7" rx="1.5" stroke="#0071E3" stroke-width="1.8" fill="none"/>
            <rect x="14" y="14" width="7" height="7" rx="1.5" stroke="#0071E3" stroke-width="1.8" fill="none"/>
          </svg>
        </view>
        <text class="share-label">生成邀请码</text>
      </view>
    </view>
  </view>
  
  <!-- Current Invited Members -->
  <view class="section">
    <text class="section-title">已邀请成员 ({{invitedMembers.length}})</text>
    <view wx:if="{{invitedMembers.length > 0}}" class="invited-list">
      <view class="invited-item" wx:for="{{invitedMembers}}" wx:for-item="member" wx:key="index">
        <view class="invited-left">
          <view class="invited-avatar" style="background-color: {{member.color}};">
            <text class="invited-avatar-text">{{member.initials}}</text>
          </view>
          <view class="invited-details">
            <text class="invited-name">{{member.name}}</text>
            <text class="invited-time">{{member.invitedTime}}</text>
          </view>
        </view>
        <text class="invited-status">已邀请</text>
      </view>
    </view>
    <view wx:else class="empty-invited">
      <text class="empty-invited-text">暂无已邀请成员</text>
    </view>
  </view>
  
  <!-- Tab bar spacer -->
  <view class="tabbar-spacer" style="height: {{tabBarHeight}}px;"></view>
</view>

<!-- Tab bar component -->
<tab-bar type="client" active="2" bind:tap="onTabTap"></tab-bar>
