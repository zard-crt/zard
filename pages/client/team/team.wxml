<!-- team.wxml v2 - 团队页 -->
<view class="page page-enter">
  <!-- Status bar spacer -->
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  
  <!-- Title -->
  <view class="title-section">
    <text class="page-title">团队</text>
  </view>
  
  <!-- Project Progress Section with animated circular indicator -->
  <view class="section">
    <text class="section-title">项目进度</text>
    <view class="progress-card card-lift">
      <view class="progress-card-header">
        <text class="progress-company">{{project.name}}</text>
        <view class="status-tag status-{{project.statusClass}}">
          <text class="status-emoji">{{project.statusEmoji}}</text>
          <text class="status-text">{{project.status}}</text>
        </view>
      </view>
      <!-- Circular progress using conic gradient -->
      <view class="circular-progress-row">
        <view class="circular-wrap">
          <view class="circular-ring" style="background: conic-gradient(#0071E3 0% {{project.completionRate}}%, #F0F0F2 {{project.completionRate}}% 100%);">
            <view class="circular-inner">
              <text class="circular-text">{{project.completionRate}}%</text>
            </view>
          </view>
        </view>
        <view class="circular-stats">
          <view class="stat-item">
            <text class="stat-number count-number">{{project.completedInterviews}}</text>
            <text class="stat-label">已完成</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-number count-number">{{project.totalInterviews}}</text>
            <text class="stat-label">总访谈</text>
          </view>
        </view>
      </view>
      <view class="progress-bar-section">
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{project.completionRate}}%;"></view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- Team Members Section -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">成员参与情况</text>
    </view>
    <view class="member-list">
      <view class="member-card stagger-item" wx:for="{{teamMembers}}" wx:for-item="member" wx:key="index">
        <view class="member-card-left">
          <view class="member-avatar" style="background: linear-gradient(135deg, {{member.color1}}, {{member.color2}});">
            <text class="member-avatar-text">{{member.initials}}</text>
          </view>
          <view class="member-details">
            <text class="member-name">{{member.name}}</text>
            <text class="member-role">{{member.role}}</text>
          </view>
        </view>
        <view class="member-status status-{{member.statusClass}}">
          <text class="status-emoji">{{member.statusEmoji}}</text>
          <text class="member-status-text">{{member.statusLabel}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- Invite Button with gradient pulse -->
  <view class="invite-section">
    <view class="invite-btn pulse-soft" bindtap="onInvite">
      <svg viewBox="0 0 20 20" width="18" height="18">
        <path d="M10 4v12M4 10h12" stroke="#0071E3" stroke-width="2.2" stroke-linecap="round"/>
      </svg>
      <text class="invite-text">邀请成员</text>
    </view>
  </view>
  
  <!-- Tab bar spacer -->
  <view class="tabbar-spacer" style="height: {{tabBarHeight}}px;"></view>
</view>

<!-- Tab bar component -->
<tab-bar type="client" active="2" bind:tap="onTabTap"></tab-bar>
