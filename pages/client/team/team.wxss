/* team.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.title-section {
  padding: 16px 0 4px;
}

.page-title {
  font-size: 26px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  line-height: 1.3;
}

.section {
  padding: 12px 0;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

/* Progress Card */
.progress-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.progress-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.progress-company {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.status-tag {
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
}

.status-text {
  font-size: 11px;
  font-weight: 500;
}

.status-active {
  background-color: #E8F5E9;
}
.status-active .status-text {
  color: #2E7D32;
}

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-text {
  color: #E65100;
}

.status-completed {
  background-color: #E3F2FD;
}
.status-completed .status-text {
  color: #0071E3;
}

.progress-stats {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 14px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.stat-number {
  font-size: 22px;
  font-weight: bold;
  color: #1D1D1F;
}

.stat-label {
  font-size: 12px;
  color: #86868B;
}

.stat-divider {
  width: 1px;
  height: 32px;
  background-color: #F0F0F2;
}

.progress-bar-section {
  padding-top: 4px;
}

.progress-bar-bg {
  height: 6px;
  background-color: #F0F0F2;
  border-radius: 3px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4A9EFF);
  border-radius: 3px;
}

/* Member List */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.member-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.member-card-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.member-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar-text {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.member-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.member-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.member-role {
  font-size: 12px;
  color: #86868B;
}

.member-status {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 10px;
  font-size: 12px;
  flex-shrink: 0;
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

/* Status variants */
.status-done {
  background-color: #E8F5E9;
}
.status-done .status-dot {
  background-color: #34C759;
}
.status-done .member-status-text {
  color: #2E7D32;
}

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-dot {
  background-color: #FF9500;
}
.status-pending .member-status-text {
  color: #E65100;
}

.status-progress {
  background-color: #E3F2FD;
}
.status-progress .status-dot {
  background-color: #0071E3;
}
.status-progress .member-status-text {
  color: #0071E3;
}

.member-status-text {
  font-size: 12px;
  font-weight: 500;
}

/* Invite Button */
.invite-section {
  padding: 20px 0;
}

.invite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 48px;
  border: 1.5px solid #0071E3;
  border-radius: 14px;
  background-color: #FFFFFF;
}

.invite-text {
  font-size: 15px;
  font-weight: 600;
  color: #0071E3;
}

.tabbar-spacer {
  width: 100%;
}
