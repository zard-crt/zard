/* team.wxss v2 - 团队页 */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* ========== Title ========== */
.title-section {
  padding: 16px 0 4px;
}

.page-title {
  font-size: 26px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  line-height: 1.3;
  animation: slideUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1) both;
}

/* ========== Section ========== */
.section {
  padding: 12px 0;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

/* ========== Progress Card ========== */
.progress-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.progress-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14px;
}

.progress-company {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

/* Status Tag with Emoji */
.status-tag {
  display: flex;
  align-items: center;
  gap: 3px;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  flex-shrink: 0;
}

.status-emoji {
  font-size: 10px;
}

.status-text {
  font-size: 11px;
  font-weight: 500;
}

.status-active {
  background-color: #E8F5E9;
}
.status-active .status-emoji { color: #2E7D32; }
.status-active .status-text { color: #2E7D32; }

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-emoji { color: #E65100; }
.status-pending .status-text { color: #E65100; }

.status-completed {
  background-color: #E3F2FD;
}
.status-completed .status-emoji { color: #0071E3; }
.status-completed .status-text { color: #0071E3; }

/* ========== Circular Progress ========== */
.circular-progress-row {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 14px;
}

.circular-wrap {
  width: 80px;
  height: 80px;
  flex-shrink: 0;
}

.circular-ring {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.circular-inner {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.circular-text {
  font-size: 18px;
  font-weight: 700;
  color: #1D1D1F;
}

.circular-stats {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  flex: 1;
}

.stat-number {
  font-size: 24px;
  font-weight: bold;
  color: #1D1D1F;
}

.stat-label {
  font-size: 12px;
  color: #86868B;
}

.stat-divider {
  width: 1px;
  height: 36px;
  background-color: #F0F0F2;
}

.progress-bar-section {
  padding-top: 4px;
}

.progress-bar-bg {
  height: 4px;
  background-color: #F0F0F2;
  border-radius: 2px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4A9EFF);
  border-radius: 2px;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ========== Member List ========== */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.member-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s cubic-bezier(0.0, 0.0, 0.2, 1);
}

.member-card:active {
  transform: scale(0.98);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

.member-card-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.member-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.member-avatar-text {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

.member-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.member-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.member-role {
  font-size: 12px;
  color: #86868B;
}

.member-status {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  border-radius: 10px;
  font-size: 12px;
  flex-shrink: 0;
}

/* Status variants */
.status-done {
  background-color: #E8F5E9;
}
.status-done .status-emoji { font-size: 11px; }
.status-done .member-status-text { color: #2E7D32; }

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-emoji { font-size: 11px; }
.status-pending .member-status-text { color: #E65100; }

.status-progress {
  background-color: #E3F2FD;
}
.status-progress .status-emoji { font-size: 11px; }
.status-progress .member-status-text { color: #0071E3; }

.member-status-text {
  font-size: 12px;
  font-weight: 500;
}

/* ========== Invite Button ========== */
.invite-section {
  padding: 20px 0;
}

.invite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  height: 48px;
  border: 1.5px solid #0071E3;
  border-radius: 14px;
  background-color: #FFFFFF;
  transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.invite-btn:active {
  background-color: rgba(0, 113, 227, 0.04);
  transform: scale(0.98);
}

.invite-text {
  font-size: 15px;
  font-weight: 600;
  color: #0071E3;
}

.tabbar-spacer {
  width: 100%;
}
