/* home.wxss */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

.title-section {
  padding: 16px 0 4px;
}

.page-title {
  font-size: 26px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  line-height: 1.3;
}

.page-subtitle {
  font-size: 13px;
  color: #86868B;
  display: block;
  margin-top: 4px;
}

/* CTA Button with breathing animation */
.cta-section {
  padding: 16px 0;
}

.scan-btn {
  background: linear-gradient(135deg, #0071E3, #0058B0);
  border-radius: 14px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  animation: breathe 2.5s ease-in-out infinite;
}

@keyframes breathe {
  0%, 100% {
    box-shadow: 0 4px 16px rgba(0, 113, 227, 0.3);
  }
  50% {
    box-shadow: 0 4px 32px rgba(0, 113, 227, 0.5);
  }
}

.scan-btn-content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.scan-icon {
  width: 22px;
  height: 22px;
}

.scan-btn-text {
  font-size: 17px;
  font-weight: 600;
  color: #FFFFFF;
}

/* Sections */
.section {
  padding: 12px 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
}

.section-link {
  font-size: 13px;
  color: #0071E3;
}

/* Project Card */
.project-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
}

.project-row {
  display: flex;
  gap: 12px;
}

.project-logo {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.project-logo-text {
  font-size: 18px;
  font-weight: bold;
  color: #FFFFFF;
}

.project-info {
  flex: 1;
  min-width: 0;
}

.project-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.project-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
}

.status-tag {
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  flex-shrink: 0;
}

.status-text {
  font-size: 11px;
  font-weight: 500;
}

.status-active {
  background-color: #E8F5E9;
}
.status-active .status-text {
  color: #2E7D32;
}

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-text {
  color: #E65100;
}

.status-completed {
  background-color: #E3F2FD;
}
.status-completed .status-text {
  color: #0071E3;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.progress-bar-bg {
  flex: 1;
  height: 6px;
  background-color: #F0F0F2;
  border-radius: 3px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4A9EFF);
  border-radius: 3px;
}

.progress-text {
  font-size: 12px;
  color: #86868B;
  width: 32px;
  text-align: right;
}

.member-avatars {
  display: flex;
  align-items: center;
}

.avatar-circle {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #0071E3;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #FFFFFF;
}

.avatar-text {
  font-size: 10px;
  font-weight: 600;
  color: #FFFFFF;
}

.avatar-more {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #F0F0F2;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #FFFFFF;
  margin-left: -8px;
}
.avatar-more .avatar-text {
  color: #86868B;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40px 0;
}

.empty-icon {
  margin-bottom: 16px;
}

.empty-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 6px;
}

.empty-desc {
  font-size: 14px;
  color: #86868B;
  margin-bottom: 20px;
}

.empty-scan-btn {
  background: linear-gradient(135deg, #0071E3, #0058B0);
  border-radius: 14px;
  height: 44px;
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-scan-text {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

/* Team Members */
.member-row {
  display: flex;
  gap: 12px;
  padding: 8px 0;
  overflow-x: auto;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.member-avatar-large {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-initials {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
}

.member-more {
  background-color: #F0F0F2;
}
.member-more .member-initials {
  color: #86868B;
}

.member-name {
  font-size: 12px;
  color: #86868B;
}

.tabbar-spacer {
  width: 100%;
}
