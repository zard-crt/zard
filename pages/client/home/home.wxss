/* home.wxss - 企业端首页 v2 */
.page {
  min-height: 100vh;
  background-color: #F5F5F7;
  padding: 0 20px;
  box-sizing: border-box;
}

.status-bar {
  width: 100%;
}

/* ========== Dynamic Island ========== */
.dynamic-island {
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 4px;
}

.island-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 120px;
  height: 26px;
  background: rgba(29, 29, 31, 0.06);
  border-radius: 20px;
  padding: 0 10px;
}

.island-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #30D158;
}

.island-time {
  font-size: 11px;
  font-weight: 600;
  color: #1D1D1F;
  letter-spacing: 0.3px;
}

.island-icons {
  display: flex;
  align-items: center;
}

/* ========== Title ========== */
.title-section {
  padding: 8px 0 12px;
}

.page-title {
  font-size: 26px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  line-height: 1.3;
  animation: slideUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1) both;
}

.page-subtitle {
  font-size: 14px;
  color: #86868B;
  display: block;
  margin-top: 2px;
  animation: slideUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1) 0.05s both;
}

/* ========== CTA Section ========== */
.cta-section {
  padding: 4px 0 16px;
  animation: slideUp 0.4s cubic-bezier(0.0, 0.0, 0.2, 1) 0.1s both;
}

.scan-btn {
  background: linear-gradient(135deg, #0071E3, #4B9EFF);
  border-radius: 16px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0, 113, 227, 0.25), 0 2px 8px rgba(0, 113, 227, 0.15);
  position: relative;
  overflow: hidden;
}

.scan-btn-content {
  display: flex;
  align-items: center;
  gap: 10px;
}

.scan-icon {
  display: block;
}

.scan-btn-text {
  font-size: 17px;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 0.3px;
}

/* ========== Section ========== */
.section {
  padding: 8px 0;
}

.section-title {
  font-size: 16px;
  font-weight: bold;
  color: #1D1D1F;
  display: block;
  margin-bottom: 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-link {
  font-size: 14px;
  font-weight: 500;
  color: #0071E3;
}

/* ========== Project Card ========== */
.projects-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.project-card {
  background-color: #FFFFFF;
  border-radius: 14px;
  padding: 0;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  overflow: hidden;
  position: relative;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s cubic-bezier(0.0, 0.0, 0.2, 1);
}

.project-card:active {
  transform: scale(0.98);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

.project-accent {
  height: 3px;
  width: 100%;
}

.project-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px;
}

.project-logo {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.project-logo-text {
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
}

.project-info {
  flex: 1;
  min-width: 0;
}

.project-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.project-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8px;
}

/* Status Tag with emoji */
.status-tag {
  display: flex;
  align-items: center;
  gap: 3px;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 11px;
  flex-shrink: 0;
}

.status-emoji {
  font-size: 10px;
}

.status-text {
  font-size: 11px;
  font-weight: 500;
}

.status-active {
  background-color: #E8F5E9;
}
.status-active .status-emoji { color: #2E7D32; }
.status-active .status-text { color: #2E7D32; }

.status-pending {
  background-color: #FFF3E0;
}
.status-pending .status-emoji { color: #E65100; }
.status-pending .status-text { color: #E65100; }

.status-completed {
  background-color: #E3F2FD;
}
.status-completed .status-emoji { color: #0071E3; }
.status-completed .status-text { color: #0071E3; }

/* Progress */
.progress-section {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}

.progress-bar-bg {
  flex: 1;
  height: 6px;
  background-color: #F0F0F2;
  border-radius: 3px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3, #4A9EFF);
  border-radius: 3px;
  transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.progress-text {
  font-size: 12px;
  color: #86868B;
  width: 32px;
  text-align: right;
  font-weight: 500;
}

/* Member Avatars */
.member-avatars {
  display: flex;
  align-items: center;
}

.avatar-circle {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #FFFFFF;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.avatar-circle:active {
  transform: scale(1.2);
}

.avatar-text {
  font-size: 10px;
  font-weight: 600;
  color: #FFFFFF;
}

.avatar-more {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: #F0F0F2;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #FFFFFF;
  margin-left: -8px;
}
.avatar-more .avatar-text {
  color: #86868B;
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48px 0;
  animation: fadeIn 0.4s cubic-bezier(0.0, 0.0, 0.2, 1) both;
}

.empty-icon {
  margin-bottom: 16px;
}

.empty-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
  margin-bottom: 6px;
}

.empty-desc {
  font-size: 14px;
  color: #86868B;
  margin-bottom: 20px;
}

.empty-scan-btn {
  background: linear-gradient(135deg, #0071E3, #0058B0);
  border-radius: 14px;
  height: 44px;
  padding: 0 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.empty-scan-text {
  font-size: 15px;
  font-weight: 600;
  color: #FFFFFF;
}

/* ========== Team Members ========== */
.member-row {
  display: flex;
  gap: 14px;
  padding: 8px 0;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.member-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  min-width: 56px;
}

.member-avatar-large {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
}

.member-initials {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
}

.member-more {
  background-color: #F0F0F2;
  border: 2px solid rgba(255, 255, 255, 0.8);
}
.member-more .member-initials {
  color: #86868B;
}

.member-name {
  font-size: 12px;
  color: #86868B;
  font-weight: 500;
}

.tabbar-spacer {
  width: 100%;
}

/* ===== Role Switch ===== */
.role-switch {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  margin: 4px 0 8px;
  background: rgba(0, 113, 227, 0.06);
  border-radius: 10px;
  border: 0.5px solid rgba(0, 113, 227, 0.12);
  width: fit-content;
  cursor: pointer;
  transition: all 0.2s;
}

.role-switch:active {
  transform: scale(0.97);
  background: rgba(0, 113, 227, 0.1);
}

.role-switch-text {
  font-size: 12px;
  font-weight: 500;
  color: #0071E3;
}

/* ===== Role Modal Overlay ===== */
.role-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.25s ease;
}

.role-modal {
  width: 100%;
  max-width: 375px;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-radius: 20px 20px 0 0;
  padding: 20px 20px calc(20px + env(safe-area-inset-bottom, 20px));
  animation: slideUp 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.role-modal-title {
  font-size: 17px;
  font-weight: 600;
  color: #1D1D1F;
  text-align: center;
  display: block;
  margin-bottom: 20px;
}

.role-option {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px;
  background: #FFFFFF;
  border-radius: 14px;
  margin-bottom: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  cursor: pointer;
  transition: all 0.2s;
}

.role-option:active {
  transform: scale(0.98);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.role-option-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.role-option-info {
  flex: 1;
}

.role-option-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
  display: block;
}

.role-option-desc {
  font-size: 12px;
  color: #86868B;
  display: block;
  margin-top: 2px;
}

.role-option-active {
  border: 1.5px solid #0071E3;
  box-shadow: 0 0 0 3px rgba(0, 113, 227, 0.08);
}

.role-modal-cancel {
  text-align: center;
  padding: 14px;
  margin-top: 8px;
  background: #F5F5F7;
  border-radius: 14px;
  cursor: pointer;
  transition: all 0.2s;
}

.role-modal-cancel:active {
  transform: scale(0.98);
}

.role-modal-cancel text {
  font-size: 15px;
  font-weight: 500;
  color: #86868B;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
