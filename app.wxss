/* ============================================
   AIDiagnose 全局样式 — Apple风格设计系统 v2
   ============================================ */

/* CSS Variables */
page {
  --color-primary: #0071E3;
  --color-primary-light: #4B9EFF;
  --color-primary-bg: rgba(0, 113, 227, 0.08);
  --color-orange: #FF9F0A;
  --color-orange-light: #FFCC02;
  --color-orange-bg: rgba(255, 159, 10, 0.1);
  --color-green: #30D158;
  --color-green-bg: rgba(48, 209, 88, 0.08);
  --color-red: #FF453A;
  --color-red-bg: rgba(255, 69, 58, 0.08);
  --color-warning: #FF9F0A;
  --color-warning-bg: rgba(255, 159, 10, 0.08);
  --color-bg: #F5F5F7;
  --color-bg-dark: #1D1D1F;
  --color-card: #FFFFFF;
  --color-card-dark: rgba(30, 30, 32, 0.65);
  --color-text: #1D1D1F;
  --color-text-secondary: #86868B;
  --color-text-tertiary: #aeaeb2;
  --color-text-dark: rgba(255, 255, 255, 0.85);
  --color-text-dark-secondary: rgba(255, 255, 255, 0.5);
  --color-border: rgba(0, 0, 0, 0.05);
  --color-border-dark: rgba(255, 255, 255, 0.08);
  --font-size-h1: 26px;
  --font-size-h2: 18px;
  --font-size-h3: 16px;
  --font-size-body: 15px;
  --font-size-caption: 13px;
  --font-size-small: 11px;
  --font-size-tab: 10px;
  --radius-card: 14px;
  --radius-button: 12px;
  --radius-input: 10px;
  --radius-tag: 8px;
  --spacing-page: 20px;
  --spacing-card: 14px;
  --spacing-gap: 10px;
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.04);
  --shadow-button: 0 2px 10px rgba(0, 113, 227, 0.2);
  --shadow-orange: 0 2px 10px rgba(255, 159, 10, 0.25);
  --font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  --ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-out: cubic-bezier(0.0, 0.0, 0.2, 1);
  --ease-in-out: cubic-bezier(0.4, 0.0, 0.2, 1);
}

/* 企业端主题 */
page.client {
  --theme-primary: var(--color-primary);
  --theme-primary-light: var(--color-primary-light);
  --theme-primary-bg: var(--color-primary-bg);
  --theme-bg: var(--color-bg);
  --theme-card: var(--color-card);
  --theme-text: var(--color-text);
  --theme-text-secondary: var(--color-text-secondary);
  --theme-border: var(--color-border);
  --theme-shadow: var(--shadow-card);
  --theme-tab-bg: rgba(255, 255, 255, 0.88);
}

/* 知晨科技端主题 */
page.opc {
  --theme-primary: var(--color-orange);
  --theme-primary-light: var(--color-orange-light);
  --theme-primary-bg: var(--color-orange-bg);
  --theme-bg: var(--color-bg-dark);
  --theme-card: var(--color-card-dark);
  --theme-text: var(--color-text-dark);
  --theme-text-secondary: var(--color-text-dark-secondary);
  --theme-border: var(--color-border-dark);
  --theme-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  --theme-tab-bg: rgba(30, 30, 32, 0.6);
}

/* 通用 */
page {
  background: var(--theme-bg, var(--color-bg));
  color: var(--theme-text, var(--color-text));
  font-family: var(--font-family);
  font-size: var(--font-size-body);
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
}

/* ========== 页面转场动画 ========== */
.page-enter {
  animation: pageEnter 0.35s var(--ease-out) both;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom, 0px);
}

.safe-area-top {
  padding-top: env(safe-area-inset-top, 0px);
}

/* ========== 滚动容器 ========== */
.scroll-container {
  padding: 0 var(--spacing-page);
  height: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ========== Typography ========== */
.h1 {
  font-size: var(--font-size-h1);
  font-weight: 700;
  letter-spacing: -0.3px;
  line-height: 1.2;
}

.h2 {
  font-size: var(--font-size-h2);
  font-weight: 600;
  line-height: 24px;
}

.h3 {
  font-size: var(--font-size-h3);
  font-weight: 600;
  line-height: 22px;
}

.body-text {
  font-size: var(--font-size-body);
  font-weight: 400;
  line-height: 20px;
}

.caption {
  font-size: var(--font-size-caption);
  font-weight: 400;
  line-height: 18px;
  color: var(--theme-text-secondary);
}

.small {
  font-size: var(--font-size-small);
  font-weight: 400;
  line-height: 14px;
  color: var(--theme-text-secondary);
}

/* ========== Buttons ========== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 14px 20px;
  border: none;
  border-radius: var(--radius-button);
  font-size: var(--font-size-body);
  font-weight: 500;
  transition: transform 0.2s var(--ease-spring), box-shadow 0.2s var(--ease-out);
}

.btn:active {
  transform: scale(0.97);
}

.btn-primary {
  background: var(--color-primary);
  color: white;
  box-shadow: var(--shadow-button);
}

.btn-orange {
  background: linear-gradient(135deg, var(--color-orange), var(--color-orange-light));
  color: white;
  box-shadow: var(--shadow-orange);
}

.btn-secondary {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid rgba(0, 113, 227, 0.15);
}

.btn-secondary-orange {
  background: transparent;
  color: var(--color-orange);
  border: 1px solid rgba(255, 159, 10, 0.15);
}

/* ========== Card ========== */
.card {
  background: var(--theme-card, var(--color-card));
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-gap);
  box-shadow: var(--theme-shadow);
  transition: transform 0.2s var(--ease-spring), box-shadow 0.2s var(--ease-out);
}

.card:active {
  transform: scale(0.98);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

/* ========== Tag ========== */
.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-tag);
  font-size: var(--font-size-small);
  font-weight: 500;
}

.tag-blue { background: rgba(0, 113, 227, 0.08); color: #0071E3; }
.tag-green { background: rgba(48, 209, 88, 0.08); color: #30D158; }
.tag-orange { background: rgba(255, 159, 10, 0.08); color: #FF9F0A; }
.tag-red { background: rgba(255, 69, 58, 0.08); color: #FF453A; }
.tag-gray { background: #F0F0F2; color: #86868B; }

/* ========== Section Header ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-gap);
}

.section-header .more {
  font-size: var(--font-size-caption);
  color: var(--theme-primary, var(--color-primary));
  font-weight: 500;
}

/* ========== Avatar ========== */
.avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  flex-shrink: 0;
}

.avatar-sm { width: 30px; height: 30px; font-size: 12px; }
.avatar-lg { width: 48px; height: 48px; font-size: 18px; }

/* ========== Flex Helpers ========== */
.flex { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.gap-4 { gap: 4px; }
.gap-6 { gap: 6px; }
.gap-8 { gap: 8px; }
.gap-10 { gap: 10px; }
.gap-12 { gap: 12px; }

/* ========== Margin ========== */
.mt-4 { margin-top: 4px; }
.mt-6 { margin-top: 6px; }
.mt-8 { margin-top: 8px; }
.mt-10 { margin-top: 10px; }
.mt-12 { margin-top: 12px; }
.mb-4 { margin-bottom: 4px; }
.mb-6 { margin-bottom: 6px; }
.mb-8 { margin-bottom: 8px; }
.mb-10 { margin-bottom: 10px; }
.mb-12 { margin-bottom: 12px; }

/* ========== Progress Bar ========== */
.progress-bar {
  height: 4px;
  background: #E8E8ED;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.5s var(--ease-spring);
}

/* ========== Status Dot ========== */
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
}

.dot-blue { background: #0071E3; }
.dot-green { background: #30D158; }
.dot-orange { background: #FF9F0A; }
.dot-gray { background: #86868B; }

/* ========== Divider ========== */
.divider {
  height: 0.5px;
  background: var(--theme-border);
  margin: 0 -14px;
}

/* ========== Empty State ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-state .empty-icon {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
  stroke: var(--theme-text-secondary, #86868B);
}

.empty-state .empty-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
}

.empty-state .empty-desc {
  font-size: 13px;
  color: var(--theme-text-secondary, #86868B);
  margin-bottom: 20px;
}

/* ========== SKELETON SCREEN ========== */
.skeleton {
  background: linear-gradient(90deg, #F0F0F2 25%, #E8E8ED 50%, #F0F0F2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6px;
}

.skeleton-text {
  height: 14px;
  margin-bottom: 8px;
  width: 80%;
}

.skeleton-text-short {
  height: 14px;
  margin-bottom: 8px;
  width: 50%;
}

.skeleton-card {
  height: 100px;
  border-radius: var(--radius-card);
  margin-bottom: var(--spacing-gap);
}

.skeleton-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== GLASS MORPHISM ========== */
.glass {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 0.5px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04), 0 1px 2px rgba(0, 0, 0, 0.02);
}

.glass-dark {
  background: rgba(30, 30, 32, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 0.5px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
}

.glass-strong {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border: 0.5px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.02);
}

/* ========== MICRO INTERACTIONS ========== */
.press-scale {
  transition: transform 0.15s var(--ease-spring);
}

.press-scale:active {
  transform: scale(0.96);
}

.card-lift {
  transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-out);
}

.card-lift:active {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
}

/* ========== STAGGERED LIST ENTRANCE ========== */
.stagger-item {
  opacity: 0;
  transform: translateY(20px);
  animation: staggerIn 0.4s var(--ease-out) forwards;
}

.stagger-item:nth-child(1) { animation-delay: 0ms; }
.stagger-item:nth-child(2) { animation-delay: 60ms; }
.stagger-item:nth-child(3) { animation-delay: 120ms; }
.stagger-item:nth-child(4) { animation-delay: 180ms; }
.stagger-item:nth-child(5) { animation-delay: 240ms; }
.stagger-item:nth-child(6) { animation-delay: 300ms; }
.stagger-item:nth-child(7) { animation-delay: 360ms; }
.stagger-item:nth-child(8) { animation-delay: 420ms; }

@keyframes staggerIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== COUNT-UP ANIMATION ========== */
.count-number {
  display: inline-block;
  animation: countPop 0.5s var(--ease-spring) both;
}

@keyframes countPop {
  0% {
    opacity: 0;
    transform: scale(0.5) translateY(10px);
  }
  100% {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* ========== BREATHING / PULSE ========== */
.pulse-animation {
  animation: pulse 2s var(--ease-in-out) infinite;
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(0, 113, 227, 0.3);
  }
  50% {
    box-shadow: 0 0 0 12px rgba(0, 113, 227, 0);
  }
}

.pulse-glow {
  animation: pulseGlow 2s var(--ease-in-out) infinite;
}

@keyframes pulseGlow {
  0%, 100% {
    box-shadow: 0 2px 12px rgba(0, 113, 227, 0.2);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 4px 24px rgba(0, 113, 227, 0.35);
    transform: scale(1.03);
  }
}

.pulse-soft {
  animation: pulseSoft 2.5s var(--ease-in-out) infinite;
}

@keyframes pulseSoft {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.65; }
}

/* ========== RIPPLE EFFECT ========== */
.ripple {
  position: relative;
  overflow: hidden;
}

.ripple::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at var(--ripple-x, 50%) var(--ripple-y, 50%), rgba(255,255,255,0.3) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.ripple:active::after {
  opacity: 1;
  animation: rippleOut 0.5s var(--ease-out);
}

@keyframes rippleOut {
  from { transform: scale(0); opacity: 0.4; }
  to { transform: scale(2.5); opacity: 0; }
}

/* ========== LOADING SPINNER ========== */
.spinner {
  width: 24px;
  height: 24px;
  border: 2.5px solid rgba(0, 113, 227, 0.1);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

.spinner-sm {
  width: 16px;
  height: 16px;
  border-width: 2px;
}

.spinner-lg {
  width: 36px;
  height: 36px;
  border-width: 3px;
}

.spinner-white {
  border-color: rgba(255, 255, 255, 0.2);
  border-top-color: #FFFFFF;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== TOAST NOTIFICATION ========== */
.toast-container {
  position: fixed;
  top: 80px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  pointer-events: none;
}

.toast {
  background: rgba(29, 29, 31, 0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  padding: 10px 20px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
  animation: toastIn 0.3s var(--ease-out) both;
  pointer-events: auto;
}

.toast.toast-hide {
  animation: toastOut 0.25s var(--ease-in) both;
}

.toast-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 14px;
  font-weight: 500;
}

.toast-icon {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
}

@keyframes toastIn {
  from {
    opacity: 0;
    transform: translateY(-16px) scale(0.92);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes toastOut {
  from {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  to {
    opacity: 0;
    transform: translateY(-16px) scale(0.92);
  }
}

/* ========== TYPING INDICATOR DOTS ========== */
.typing-dots {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 0;
}

.typing-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #C7C7CC;
  animation: typingBounce 1.4s var(--ease-in-out) infinite both;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* ========== SLIDE-UP ENTRANCE ========== */
.slide-up {
  animation: slideUp 0.35s var(--ease-out) both;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== FADE IN ========== */
.fade-in {
  animation: fadeIn 0.3s var(--ease-out) both;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ========== SCALE IN ========== */
.scale-in {
  animation: scaleIn 0.3s var(--ease-spring) both;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.92);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
