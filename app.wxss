/* ============================================
   AIDiagnose 全局样式 — Apple风格设计系统
   ============================================ */

/* CSS Variables */
page {
  --color-primary: #0071E3;
  --color-primary-light: #4B9EFF;
  --color-primary-bg: rgba(0, 113, 227, 0.08);
  --color-orange: #FF9F0A;
  --color-orange-light: #FFCC02;
  --color-orange-bg: rgba(255, 159, 10, 0.1);
  --color-green: #30D158;
  --color-green-bg: rgba(48, 209, 88, 0.08);
  --color-red: #FF453A;
  --color-red-bg: rgba(255, 69, 58, 0.08);
  --color-warning: #FF9F0A;
  --color-warning-bg: rgba(255, 159, 10, 0.08);
  --color-bg: #F5F5F7;
  --color-bg-dark: #1D1D1F;
  --color-card: #FFFFFF;
  --color-card-dark: rgba(30, 30, 32, 0.65);
  --color-text: #1D1D1F;
  --color-text-secondary: #86868B;
  --color-text-tertiary: #aeaeb2;
  --color-text-dark: rgba(255, 255, 255, 0.85);
  --color-text-dark-secondary: rgba(255, 255, 255, 0.5);
  --color-border: rgba(0, 0, 0, 0.05);
  --color-border-dark: rgba(255, 255, 255, 0.08);
  --font-size-h1: 26px;
  --font-size-h2: 18px;
  --font-size-h3: 16px;
  --font-size-body: 15px;
  --font-size-caption: 13px;
  --font-size-small: 11px;
  --font-size-tab: 10px;
  --radius-card: 14px;
  --radius-button: 12px;
  --radius-input: 10px;
  --radius-tag: 8px;
  --spacing-page: 20px;
  --spacing-card: 14px;
  --spacing-gap: 10px;
  --shadow-card: 0 2px 12px rgba(0, 0, 0, 0.04);
  --shadow-button: 0 2px 10px rgba(0, 113, 227, 0.2);
  --shadow-orange: 0 2px 10px rgba(255, 159, 10, 0.25);
  --font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

/* 企业端主题 */
page.client {
  --theme-primary: var(--color-primary);
  --theme-primary-light: var(--color-primary-light);
  --theme-primary-bg: var(--color-primary-bg);
  --theme-bg: var(--color-bg);
  --theme-card: var(--color-card);
  --theme-text: var(--color-text);
  --theme-text-secondary: var(--color-text-secondary);
  --theme-border: var(--color-border);
  --theme-shadow: var(--shadow-card);
  --theme-tab-bg: rgba(255, 255, 255, 0.88);
}

/* 知晨科技端主题 */
page.opc {
  --theme-primary: var(--color-orange);
  --theme-primary-light: var(--color-orange-light);
  --theme-primary-bg: var(--color-orange-bg);
  --theme-bg: var(--color-bg-dark);
  --theme-card: var(--color-card-dark);
  --theme-text: var(--color-text-dark);
  --theme-text-secondary: var(--color-text-dark-secondary);
  --theme-border: var(--color-border-dark);
  --theme-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  --theme-tab-bg: rgba(30, 30, 32, 0.6);
}

/* 通用 */
page {
  background: var(--theme-bg, var(--color-bg));
  color: var(--theme-text, var(--color-text));
  font-family: var(--font-family);
  font-size: var(--font-size-body);
  line-height: 1.4;
  -webkit-font-smoothing: antialiased;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 滚动容器 */
.scroll-container {
  padding: 0 var(--spacing-page);
  height: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* Typography */
.h1 {
  font-size: var(--font-size-h1);
  font-weight: 700;
  letter-spacing: -0.3px;
  line-height: 1.2;
}

.h2 {
  font-size: var(--font-size-h2);
  font-weight: 600;
  line-height: 24px;
}

.h3 {
  font-size: var(--font-size-h3);
  font-weight: 600;
  line-height: 22px;
}

.body-text {
  font-size: var(--font-size-body);
  font-weight: 400;
  line-height: 20px;
}

.caption {
  font-size: var(--font-size-caption);
  font-weight: 400;
  line-height: 18px;
  color: var(--theme-text-secondary);
}

.small {
  font-size: var(--font-size-small);
  font-weight: 400;
  line-height: 14px;
  color: var(--theme-text-secondary);
}

/* Buttons */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 14px 20px;
  border: none;
  border-radius: var(--radius-button);
  font-size: var(--font-size-body);
  font-weight: 500;
  transition: transform 0.2s;
}

.btn:active {
  transform: scale(0.97);
}

.btn-primary {
  background: var(--color-primary);
  color: white;
  box-shadow: var(--shadow-button);
}

.btn-orange {
  background: linear-gradient(135deg, var(--color-orange), var(--color-orange-light));
  color: white;
  box-shadow: var(--shadow-orange);
}

.btn-secondary {
  background: transparent;
  color: var(--color-primary);
  border: 1px solid rgba(0, 113, 227, 0.15);
}

.btn-secondary-orange {
  background: transparent;
  color: var(--color-orange);
  border: 1px solid rgba(255, 159, 10, 0.15);
}

/* Card */
.card {
  background: var(--theme-card, var(--color-card));
  border-radius: var(--radius-card);
  padding: var(--spacing-card);
  margin-bottom: var(--spacing-gap);
  box-shadow: var(--theme-shadow);
}

/* Tag */
.tag {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-tag);
  font-size: var(--font-size-small);
  font-weight: 500;
}

.tag-blue { background: rgba(0, 113, 227, 0.08); color: #0071E3; }
.tag-green { background: rgba(48, 209, 88, 0.08); color: #30D158; }
.tag-orange { background: rgba(255, 159, 10, 0.08); color: #FF9F0A; }
.tag-red { background: rgba(255, 69, 58, 0.08); color: #FF453A; }
.tag-gray { background: #F0F0F2; color: #86868B; }

/* Section Header */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-gap);
}

.section-header .more {
  font-size: var(--font-size-caption);
  color: var(--theme-primary, var(--color-primary));
  font-weight: 500;
}

/* Avatar */
.avatar {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  flex-shrink: 0;
}

.avatar-sm { width: 30px; height: 30px; font-size: 12px; }
.avatar-lg { width: 48px; height: 48px; font-size: 18px; }

/* Flex Helpers */
.flex { display: flex; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-col { display: flex; flex-direction: column; }
.flex-1 { flex: 1; }
.gap-4 { gap: 4px; }
.gap-6 { gap: 6px; }
.gap-8 { gap: 8px; }
.gap-10 { gap: 10px; }
.gap-12 { gap: 12px; }

/* Margin */
.mt-4 { margin-top: 4px; }
.mt-6 { margin-top: 6px; }
.mt-8 { margin-top: 8px; }
.mt-10 { margin-top: 10px; }
.mt-12 { margin-top: 12px; }
.mb-4 { margin-bottom: 4px; }
.mb-6 { margin-bottom: 6px; }
.mb-8 { margin-bottom: 8px; }
.mb-10 { margin-bottom: 10px; }
.mb-12 { margin-bottom: 12px; }

/* Progress Bar */
.progress-bar {
  height: 4px;
  background: #E8E8ED;
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Status Dot */
.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
}

.dot-blue { background: #0071E3; }
.dot-green { background: #30D158; }
.dot-orange { background: #FF9F0A; }
.dot-gray { background: #86868B; }

/* Divider */
.divider {
  height: 0.5px;
  background: var(--theme-border);
  margin: 0 -14px;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-state .empty-icon {
  width: 64px;
  height: 64px;
  margin-bottom: 16px;
  stroke: var(--theme-text-secondary, #86868B);
}

.empty-state .empty-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 4px;
}

.empty-state .empty-desc {
  font-size: 13px;
  color: var(--theme-text-secondary, #86868B);
  margin-bottom: 20px;
}
