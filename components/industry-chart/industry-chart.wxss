.industry-chart {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 4px 0;
}

.chart-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
}

.chart-label {
  width: 72px;
  flex-shrink: 0;
}

.chart-label-text {
  font-size: 13px;
  font-weight: 400;
  color: #86868B;
  line-height: 1.3;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.industry-chart--opc .chart-label-text {
  color: rgba(255, 255, 255, 0.6);
}

.chart-bar-track {
  flex: 1;
  height: 8px;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 4px;
  overflow: hidden;
}

.industry-chart--opc .chart-bar-track {
  background: rgba(255, 255, 255, 0.08);
}

.chart-bar-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.6s ease;
}

.chart-bar-fill--client {
  background: linear-gradient(90deg, #0071E3 0%, #40A9FF 100%);
}

.chart-bar-fill--opc {
  background: linear-gradient(90deg, #FF9F0A 0%, #FFCC00 100%);
}

.chart-value {
  width: 40px;
  flex-shrink: 0;
  text-align: right;
}

.chart-value-text {
  font-size: 12px;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.3;
}

.industry-chart--opc .chart-value-text {
  color: #FFFFFF;
}
