.avatar-group {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar-item {
  flex-shrink: 0;
  border-radius: 50%;
  border: 2px solid #FFFFFF;
}

.avatar-item--sm {
  width: 24px;
  height: 24px;
}

.avatar-item--md {
  width: 32px;
  height: 32px;
}

.avatar-circle {
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-circle--sm {
  width: 24px;
  height: 24px;
}

.avatar-circle--md {
  width: 32px;
  height: 32px;
}

.avatar-circle--overflow {
  background: #E8E8ED;
}

.avatar-text {
  font-weight: 500;
  color: #FFFFFF;
  text-align: center;
}

.avatar-text--sm {
  font-size: 10px;
  line-height: 24px;
}

.avatar-text--md {
  font-size: 12px;
  line-height: 32px;
}

.avatar-circle--overflow .avatar-text {
  color: #86868B;
}

.avatar-circle--blue {
  background: #0071E3;
}

.avatar-circle--green {
  background: #34C759;
}

.avatar-circle--orange {
  background: #FF9F0A;
}

.avatar-circle--red {
  background: #FF3B30;
}

.avatar-circle--purple {
  background: #AF52DE;
}

.avatar-circle--teal {
  background: #5AC8FA;
}

.avatar-circle--pink {
  background: #FF2D55;
}

.avatar-circle--gray {
  background: #8E8E93;
}
