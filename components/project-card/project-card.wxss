.project-card {
  background: #FFFFFF;
  border-radius: 14px;
  padding: 14px;
  margin-bottom: 10px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.company-avatar {
  width: 38px;
  height: 38px;
  border-radius: 19px;
  background: linear-gradient(135deg, #0071E3 0%, #40A9FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.company-initial {
  font-size: 16px;
  font-weight: 600;
  color: #FFFFFF;
}

.card-info {
  flex: 1;
  margin-left: 12px;
  min-width: 0;
}

.company-name {
  font-size: 15px;
  font-weight: 600;
  color: #1D1D1F;
  line-height: 1.3;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-meta {
  margin-top: 4px;
}

.project-status {
  font-size: 12px;
  font-weight: 500;
  padding: 2px 8px;
  border-radius: 4px;
  display: inline-block;
}

.project-status--in_progress {
  background: rgba(0, 113, 227, 0.1);
  color: #0071E3;
}

.project-status--completed {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

.project-status--pending {
  background: rgba(255, 159, 10, 0.1);
  color: #FF9F0A;
}

.project-status--reviewing {
  background: rgba(175, 82, 222, 0.1);
  color: #AF52DE;
}

.project-status--delivered {
  background: rgba(0, 200, 200, 0.1);
  color: #00C8C8;
}

.progress-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 12px;
  gap: 8px;
}

.progress-bar {
  flex: 1;
  height: 4px;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0071E3 0%, #40A9FF 100%);
  border-radius: 2px;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 11px;
  font-weight: 500;
  color: #86868B;
  width: 32px;
  text-align: right;
}

.card-footer {
  margin-top: 10px;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
}
