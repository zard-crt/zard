.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  height: 80px;
  padding-bottom: env(safe-area-inset-bottom, 20px);
  padding-top: 6px;
  box-sizing: border-box;
  z-index: 1000;
}

.tab-bar--client {
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-top: 0.5px solid rgba(0, 0, 0, 0.05);
}

.tab-bar--opc {
  background: rgba(30, 30, 32, 0.6);
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-top: 0.5px solid rgba(255, 255, 255, 0.05);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1px;
  flex: 1;
  height: 60px;
  padding: 0;
  border: none;
  background: transparent;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  position: relative;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item:active {
  transform: scale(0.92);
}

.tab-icon-wrapper {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-item--active .tab-icon-wrapper {
  transform: scale(1.1);
}

.tab-icon {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon-svg {
  display: block;
  transition: all 0.3s ease;
}

.tab-label {
  font-size: 10px;
  font-weight: 500;
  line-height: 1;
  text-align: center;
  transition: all 0.3s ease;
  margin-top: 2px;
}

.tab-bar--client .tab-label {
  color: #86868B;
}

.tab-bar--opc .tab-label {
  color: rgba(255, 255, 255, 0.3);
}

.tab-item--active .tab-label {
  font-weight: 700;
  letter-spacing: 0.3px;
}

.tab-bar--client .tab-item--active .tab-label {
  color: #0071E3;
}

.tab-bar--opc .tab-item--active .tab-label {
  color: #FF9F0A;
}

/* Underline indicator */
.tab-indicator {
  position: absolute;
  bottom: 4px;
  left: 50%;
  width: 0;
  height: 2px;
  border-radius: 1px;
  transform: translateX(-50%);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tab-bar--client .tab-indicator--active {
  width: 20px;
  background: #0071E3;
}

.tab-bar--opc .tab-indicator--active {
  width: 20px;
  background: #FF9F0A;
}
